# Admin panel (protects /admin)
ADMIN_PASSWORD=choose-a-strong-password
ADMIN_SESSION_SECRET=generate-with:-openssl-rand-base64-32

# Contact form -> email notifications (SMTP). Leave unset to skip sending
# email; submissions are still stored and visible in /admin.
# Example for Gmail: host smtp.gmail.com, port 587, and an App Password
# (not your regular password) as SMTP_PASS.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
CONTACT_TO_EMAIL=

# WhatsApp click-to-chat button (public). Use full international number,
# digits only, no + or spaces, e.g. 14155552671
NEXT_PUBLIC_WHATSAPP_NUMBER=
